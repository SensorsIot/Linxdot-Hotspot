#!/bin/sh
#
# S80dockercompose — Start Basics Station container via docker-compose.
#
# Layers 2 + 3 of the basicstation self-healing stack:
#   * Layer 2: reset retry — call reset.sh (with readback verification) up to
#     RESET_MAX times before giving up on a single attempt.
#   * Layer 3: post-up EUI check — after the container starts, scan its log
#     for "EUI Source: chip" vs "eth0". On eth0 fallback the chip didn't
#     answer SPI even though GPIOs are right; restart the container and try
#     again, up to ATTEMPT_MAX whole cycles.
#
# Every step logs a single structured line via `logger -t basicstation-init`
# so `logread | grep basicstation-init` shows the entire boot story.
#

SYS_CONF=/etc/docker-compose.yml
USER_CONF=/data/docker-compose.yml
PROG=/usr/bin/docker-compose
LOG=/var/log/docker-compose.log
RESET_SCRIPT=/opt/basicstation/reset.sh
TC_KEY_FILE=/data/basicstation/tc_key.txt
REGION_FILE=/data/basicstation/region.env

# Self-heal tunables
RESET_MAX=3            # reset.sh retries within one whole cycle
ATTEMPT_MAX=3          # whole reset+container cycles before giving up
EUI_WAIT=30            # seconds to wait for "EUI Source:" line per cycle

[ -x "$PROG" ] || exit 0

say() {
    # Mirror message to stdout (console at boot), syslog (logread), and $LOG
    # so a single grep finds the whole story regardless of where the operator
    # looks first.
    echo "S80dockercompose: $*"
    logger -t basicstation-init "$*"
    echo "$(date -Iseconds) $*" >> "$LOG" 2>/dev/null || true
}

# Read TC_KEY from file (skip comment lines)
load_tc_key() {
    if [ -f "$TC_KEY_FILE" ]; then
        TC_KEY=$(grep -v '^#' "$TC_KEY_FILE" | grep -v '^$' | head -1 | tr -d '[:space:]')
        if [ -n "$TC_KEY" ]; then
            export TC_KEY
            return 0
        fi
    fi
    return 1
}

# Read TTS_REGION from /data/basicstation/region.env if present (default: eu1
# applied via ${TTS_REGION:-eu1} in /etc/docker-compose.yml).
load_region() {
    if [ -f "$REGION_FILE" ]; then
        # shellcheck source=/dev/null
        . "$REGION_FILE"
        [ -n "$TTS_REGION" ] && export TTS_REGION
    fi
}

# Pre-v1.0.7 the wizard wrote /data/docker-compose.yml as a full copy of the
# rootfs compose with TTS_REGION substituted. Two problems with that on v1.0.7+:
# the /data copy carries STATION_RADIOINIT (which the new rootfs intentionally
# drops to fix the SX1250 reset race), and it freezes any future compose-file
# change. Extract any region the operator picked into region.env and archive
# the override.
migrate_region_override() {
    [ -f "$USER_CONF" ] || return 0
    # Skip if the override already uses the v1.0.7 env-interpolation form.
    grep -q 'TTS_REGION:.*\${' "$USER_CONF" && return 0
    region=$(sed -n 's/.*TTS_REGION:[[:space:]]*"\{0,1\}\([a-z0-9]*\).*/\1/p' "$USER_CONF" | head -1)
    if [ -n "$region" ] && [ ! -f "$REGION_FILE" ]; then
        say "migrating $USER_CONF -> $REGION_FILE (region=$region)"
        echo "TTS_REGION=$region" > "$REGION_FILE"
    fi
    mv "$USER_CONF" "${USER_CONF}.pre-v1.0.7.bak"
}

# Pick config file (after migration may have removed an obsolete override).
select_conf() {
    if [ -f "$USER_CONF" ]; then
        CONF="$USER_CONF"
    else
        CONF="$SYS_CONF"
    fi
    [ -s "$CONF" ]
}

wait_for_docker() {
    for i in $(seq 1 60); do
        [ -S /var/run/docker.sock ] && docker info >/dev/null 2>&1 && return 0
        sleep 1
    done
    say "ERROR dockerd not ready after 60s"
    return 1
}

# Run reset.sh stop+start with readback verification. reset.sh is verbose; we
# capture its stdout/stderr to $LOG and report a single summary line via say().
# Returns 0 only if reset.sh exits 0 (i.e., GPIO readback matched).
reset_once() {
    if [ ! -x "$RESET_SCRIPT" ]; then
        say "ERROR reset script missing or not executable: $RESET_SCRIPT"
        return 1
    fi
    "$RESET_SCRIPT" stop  >> "$LOG" 2>&1 || true   # stop may fail on fresh boot
    sleep 1
    if "$RESET_SCRIPT" start >> "$LOG" 2>&1; then
        sleep 2   # SX1302 PLL/TCXO settle
        return 0
    fi
    return 1
}

# Layer 2: reset.sh retry.
reset_with_retry() {
    n=1
    while [ "$n" -le "$RESET_MAX" ]; do
        say "reset attempt $n/$RESET_MAX"
        if reset_once; then
            say "reset attempt $n/$RESET_MAX OK"
            return 0
        fi
        say "reset attempt $n/$RESET_MAX failed (see $LOG for reset.sh output)"
        sleep $((n * 2))
        n=$((n + 1))
    done
    say "ERROR concentrator reset failed after $RESET_MAX attempts"
    return 1
}

# Compute the eth0-fallback EUI64 the container would synthesise from the
# eth0 MAC if its chip-EUI read failed (EUI-48 → EUI-64 by inserting FFFE in
# the middle). Empty if eth0 isn't present, which is treated as "can't tell"
# downstream.
eth0_fallback_eui() {
    mac=$(cat /sys/class/net/eth0/address 2>/dev/null | tr -d ':' | tr 'a-f' 'A-F')
    [ "${#mac}" -eq 12 ] || return 1
    # 0c8629e02109 -> 0C8629FFFEE02109
    echo "$mac" | sed 's/^\(......\)\(......\)$/\1FFFE\2/'
}

# Layer 3: confirm the container is using the chip EUI (not the eth0 fallback).
# The entrypoint's "EUI Source:" label is ambiguous — it can be 'chip' (just
# read), 'eth0' (fallback), or 'file' (reused station.conf which may hold
# *either* a chip or a stale eth0 EUI from a previous boot). We compare the
# actual Gateway EUI value against the deterministic eth0 fallback instead.
# Returns 0 = healthy (chip EUI in use), 1 = eth0 fallback or unknown.
verify_chip_eui() {
    eth0_eui=$(eth0_fallback_eui || echo "")
    waited=0
    while [ "$waited" -lt "$EUI_WAIT" ]; do
        # Container logs the EUI inside ANSI colour codes; extract 16 hex
        # chars from the last Gateway EUI line directly to dodge busybox
        # sed's lack of \x1b support.
        gw_eui=$(docker logs basicstation 2>&1 \
                 | grep "Gateway EUI:" | tail -1 \
                 | grep -oE '[0-9A-F]{16}')
        if [ -n "$gw_eui" ]; then
            if [ -n "$eth0_eui" ] && [ "$gw_eui" = "$eth0_eui" ]; then
                say "container Gateway EUI=$gw_eui matches eth0 fallback — chip read failed in container"
                return 1
            fi
            say "container Gateway EUI=$gw_eui (chip EUI in use)"
            return 0
        fi
        sleep 2
        waited=$((waited + 2))
    done
    say "container did not log Gateway EUI within ${EUI_WAIT}s"
    return 1
}

# Bring the container up. First cycle does a `pull` (in case the image was
# updated); later cycles in the recovery loop just restart, so a slow registry
# can't extend the chip-warm window.
container_up() {
    cycle=$1
    if [ "$cycle" -eq 1 ]; then
        export COMPOSE_HTTP_TIMEOUT=300
        say "docker-compose pull"
        $PROG -f "$CONF" pull >> "$LOG" 2>&1 || say "WARN pull failed (continuing with local image)"
        say "docker-compose up -d"
        $PROG -f "$CONF" up -d >> "$LOG" 2>&1
    else
        say "restarting container (cycle $cycle)"
        if docker restart basicstation >> "$LOG" 2>&1; then
            return 0
        fi
        # Fallback if container was destroyed somehow
        $PROG -f "$CONF" up -d >> "$LOG" 2>&1
    fi
}

# Layers 2 + 3 orchestrator.
start_with_recovery() {
    cycle=1
    while [ "$cycle" -le "$ATTEMPT_MAX" ]; do
        say "=== self-heal cycle $cycle/$ATTEMPT_MAX ==="
        if ! reset_with_retry; then
            cycle=$((cycle + 1))
            continue
        fi

        container_up "$cycle"

        if verify_chip_eui; then
            say "OK gateway up with chip EUI on cycle $cycle"
            return 0
        fi

        cycle=$((cycle + 1))
    done

    say "ERROR gateway running with eth0 EUI after $ATTEMPT_MAX cycles — will not connect to TTN"
    say "ERROR manual intervention required: check /var/log/docker-compose.log and 'docker logs basicstation'"
    return 1
}

case "$1" in
    start)
        migrate_region_override
        select_conf || exit 0

        # Load TC_KEY from config file
        if ! load_tc_key; then
            say "TC_KEY not configured in $TC_KEY_FILE"
            say "Edit the file and add your TTN API key to connect"
            exit 0
        fi
        load_region

        say "waiting for Docker"
        wait_for_docker || exit 1

        start_with_recovery || exit 0
        ;;
    stop)
        select_conf || exit 0
        say "stopping containers"
        $PROG -f "$CONF" stop >> "$LOG" 2>&1
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    status)
        echo "=== Basics Station Status ==="
        if load_tc_key; then
            echo "TC_KEY: configured (${#TC_KEY} chars)"
        else
            echo "TC_KEY: NOT CONFIGURED"
            echo "  Edit $TC_KEY_FILE and add your TTN API key"
        fi
        echo ""
        if [ -x "$RESET_SCRIPT" ]; then
            echo "Reset script: OK ($RESET_SCRIPT)"
        else
            echo "Reset script: MISSING ($RESET_SCRIPT)"
        fi
        echo ""
        echo "Docker containers:"
        docker ps -a --filter "name=basicstation" --format "  {{.Names}}: {{.Status}}" 2>/dev/null || echo "  (docker not available)"
        echo ""
        echo "Last EUI Source seen by container:"
        docker logs basicstation 2>&1 | grep "EUI Source:" | tail -1 || echo "  (no EUI line yet)"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
