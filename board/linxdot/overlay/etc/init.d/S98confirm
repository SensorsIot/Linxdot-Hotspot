#!/bin/sh
# S98confirm — commit the current slot after a healthy trial boot.
#
# If upgrade_available=1 (we're trial-booting a newly-applied update),
# wait for the configured health condition, then clear the trial flags.
# Otherwise U-Boot will roll us back on next reboot.
#
# OTA-only firmware: "healthy" means the OTA path itself still works —
# default route, clock-bootstrap, and ota-check --dry-run reach the
# upstream manifest. The bar that matters is that this slot can receive
# the NEXT update. If it can't, we rolled into a soft-brick and U-Boot
# should put us back on the previous slot.

case "$1" in
    start) ;;
    stop|*) exit 0 ;;
esac

[ "$(fw_printenv -n upgrade_available 2>/dev/null)" = "1" ] || exit 0

# Load defaults, then let /data/ota.conf override them.
HEALTH_CHECK=full
HEALTH_TIMEOUT=300
[ -r /etc/default/ota ] && . /etc/default/ota
[ -r /data/ota.conf ]   && . /data/ota.conf

SLOT=$(fw_printenv -n boot_slot 2>/dev/null || echo "?")
logger -t ota "trial boot of slot $SLOT — health_check=$HEALTH_CHECK timeout=${HEALTH_TIMEOUT}s"

have_route()  { ip route get 1.1.1.1 >/dev/null 2>&1; }
have_clock()  { /usr/sbin/clock-bootstrap >/dev/null 2>&1; }
have_upstream() { /usr/sbin/ota-check --dry-run >/dev/null 2>&1; }

is_healthy() {
    case "$HEALTH_CHECK" in
        always)  return 0 ;;
        never)   return 1 ;;
        network) have_route && have_clock ;;
        full|*)  have_route && have_clock && have_upstream ;;
    esac
}

HEALTHY=0
polls=$(( HEALTH_TIMEOUT / 5 ))
[ "$polls" -lt 1 ] && polls=1
for _ in $(seq 1 "$polls"); do
    if is_healthy; then
        HEALTHY=1
        break
    fi
    sleep 5
done

if [ "$HEALTHY" -eq 1 ]; then
    fw_setenv upgrade_available 0
    fw_setenv bootcount 0
    logger -t ota "slot $SLOT committed (health_check=$HEALTH_CHECK)"
else
    logger -t ota "slot $SLOT health check FAILED (health_check=$HEALTH_CHECK) — rollback on next reboot"
fi

exit 0
