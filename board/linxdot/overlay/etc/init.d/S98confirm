#!/bin/sh
# S98confirm — commit the current slot after a healthy trial boot.
#
# If upgrade_available=1 (we're trial-booting a newly-applied update),
# wait for the configured health condition, then clear the trial flags.
# Otherwise U-Boot will roll us back on next reboot.
#
# Health condition is configurable via /etc/default/ota (baked into
# the rootfs) and /data/ota.conf (persistent, overrides the default).
# See the defaults file for the supported HEALTH_CHECK values.

case "$1" in
    start) ;;
    stop|*) exit 0 ;;
esac

[ "$(fw_printenv -n upgrade_available 2>/dev/null)" = "1" ] || exit 0

# Load defaults, then let /data/ota.conf override them.
HEALTH_CHECK=full
HEALTH_TIMEOUT=120
[ -r /etc/default/ota ] && . /etc/default/ota
[ -r /data/ota.conf ]   && . /data/ota.conf

SLOT=$(fw_printenv -n boot_slot 2>/dev/null || echo "?")
logger -t ota "trial boot of slot $SLOT — health_check=$HEALTH_CHECK timeout=${HEALTH_TIMEOUT}s"

gateway_eui_is_chip() {
    # Compare actual Gateway EUI against the deterministic eth0 fallback the
    # entrypoint would synthesise (EUI-48 -> EUI-64 with FFFE inserted). The
    # "EUI Source:" label can be 'file' for a station.conf reused from a
    # prior run holding *either* a chip or eth0 EUI, so the value is the
    # only reliable signal.
    mac=$(cat /sys/class/net/eth0/address 2>/dev/null | tr -d ':' | tr 'a-f' 'A-F')
    [ "${#mac}" -eq 12 ] || return 1
    eth0_eui=$(echo "$mac" | sed 's/^\(......\)\(......\)$/\1FFFE\2/')
    gw_eui=$(docker logs basicstation 2>&1 \
             | grep "Gateway EUI:" | tail -1 \
             | grep -oE '[0-9A-F]{16}')
    [ -n "$gw_eui" ] || return 1
    [ "$gw_eui" != "$eth0_eui" ]
}

is_healthy() {
    case "$HEALTH_CHECK" in
        always)
            return 0 ;;
        never)
            return 1 ;;
        minimal)
            pidof dockerd >/dev/null 2>&1 ;;
        container)
            pidof dockerd >/dev/null 2>&1 \
                && docker ps --format '{{.Names}}' 2>/dev/null | grep -q basicstation ;;
        full|*)
            # full: dockerd up, basicstation container running, AND container
            # is using the chip EUI (not the eth0 MAC fallback). An eth0
            # fallback won't connect to TTN, so we treat it as a failed trial
            # and let U-Boot roll back to the previous slot.
            pidof dockerd >/dev/null 2>&1 \
                && docker ps --format '{{.Names}}' 2>/dev/null | grep -q basicstation \
                && gateway_eui_is_chip ;;
    esac
}

HEALTHY=0
# Poll every 5s for up to HEALTH_TIMEOUT seconds.
polls=$(( HEALTH_TIMEOUT / 5 ))
[ "$polls" -lt 1 ] && polls=1
for _ in $(seq 1 "$polls"); do
    if is_healthy; then
        HEALTHY=1
        break
    fi
    sleep 5
done

if [ "$HEALTHY" -eq 1 ]; then
    fw_setenv upgrade_available 0
    fw_setenv bootcount 0
    logger -t ota "slot $SLOT committed (health_check=$HEALTH_CHECK)"
else
    logger -t ota "slot $SLOT health check FAILED (health_check=$HEALTH_CHECK) — rollback on next reboot"
fi

exit 0
