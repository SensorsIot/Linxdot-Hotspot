#!/bin/sh
#
# S40network - Bring up eth0 with DHCP
#

LINK_TIMEOUT=30
EMMC_BOOT0="/dev/mmcblk1boot0"
DATA_MAC="/data/eth0_mac"

# Fixed third-tier fallback MAC. Used on a freshly-flashed device until the
# operator runs `set-eth-mac` to bind the case sticker MAC into the eMMC HW
# boot partition. Locally-administered, unicast — not globally unique by
# design, so every fresh OpenLinxdot device announces this same address.
# Operators provisioning multiple devices on one LAN must do them one at a
# time.
SETUP_MAC="02:00:5d:01:01:01"

# Read a stored MAC from /dev/mmcblk1boot0. The eMMC HW boot partition lives
# outside the GPT, so MACs written by /usr/sbin/set-eth-mac survive both OTA
# and full factory re-flashes. Layout: 8-byte "OLNXMAC1" magic, 6 raw MAC
# bytes, 18 zero bytes. Echoes a colon-separated MAC and returns 0 on success.
read_emmc_mac() {
    [ -b "$EMMC_BOOT0" ] || return 1
    raw=$(dd if="$EMMC_BOOT0" bs=1 count=14 status=none 2>/dev/null \
          | od -An -tx1 | tr -d ' \n')
    [ "${#raw}" = 28 ] || return 1
    # First 8 bytes (16 hex chars) must be "OLNXMAC1" = 4f4c4e584d414331.
    [ "$(echo "$raw" | cut -c1-16)" = "4f4c4e584d414331" ] || return 1
    b1=$(echo "$raw" | cut -c17-18)
    b2=$(echo "$raw" | cut -c19-20)
    b3=$(echo "$raw" | cut -c21-22)
    b4=$(echo "$raw" | cut -c23-24)
    b5=$(echo "$raw" | cut -c25-26)
    b6=$(echo "$raw" | cut -c27-28)
    # Reject all-zero, all-ones, and multicast.
    case "$b1$b2$b3$b4$b5$b6" in
        000000000000|ffffffffffff|FFFFFFFFFFFF) return 1 ;;
    esac
    [ $(( 0x$b1 & 0x01 )) -eq 0 ] || return 1
    echo "$b1:$b2:$b3:$b4:$b5:$b6"
}

# Read an admin override from /data/eth0_mac (single-line "aa:bb:cc:dd:ee:ff").
read_data_mac() {
    [ -r "$DATA_MAC" ] || return 1
    mac=$(head -n1 "$DATA_MAC" 2>/dev/null | tr -d '[:space:]')
    case "$mac" in
        [0-9a-fA-F][0-9a-fA-F]:[0-9a-fA-F][0-9a-fA-F]:[0-9a-fA-F][0-9a-fA-F]:[0-9a-fA-F][0-9a-fA-F]:[0-9a-fA-F][0-9a-fA-F]:[0-9a-fA-F][0-9a-fA-F])
            echo "$mac"
            ;;
        *) return 1 ;;
    esac
}

set_mac() {
    if mac=$(read_emmc_mac); then
        ip link set dev eth0 address "$mac"
        echo "S40network: eth0 MAC set to $mac (from $EMMC_BOOT0)"
        return
    fi
    if mac=$(read_data_mac); then
        ip link set dev eth0 address "$mac"
        echo "S40network: eth0 MAC set to $mac (from $DATA_MAC)"
        return
    fi
    # Fresh device — assign the fixed setup MAC and ask the operator to
    # run set-eth-mac. See SETUP_MAC comment above for the rationale.
    ip link set dev eth0 address "$SETUP_MAC"
    echo "S40network: eth0 MAC set to $SETUP_MAC (setup fallback — run set-eth-mac)"
}

start_lo() {
    ifconfig lo up
}

start_eth() {
    set_mac
    echo "S40network: waiting for eth0 link"
    ifconfig eth0 up

    count=0
    while [ "$(cat /sys/class/net/eth0/carrier 2>/dev/null)" != "1" ]; do
        sleep 1
        count=$((count + 1))
        if [ $count -ge $LINK_TIMEOUT ]; then
            echo "S40network: eth0 no link after ${LINK_TIMEOUT}s"
            return 1
        fi
    done

    echo "S40network: eth0 link detected, starting DHCP"
    udhcpc -b -i eth0 -p /var/run/udhcpc.eth0.pid

    # Self-verify each step. Continuing past a failed prerequisite is
    # pointless — S49ntp without a route, S60ota without a clock, all
    # fail 100%. So this function is "all or nothing": every check must
    # pass within its own timeout, otherwise return 1 and let the caller
    # decide (bounded-reboot recovery in start_eth_with_recovery).

    # Step 1: default route present (lease arrived).
    echo "S40network: verify default route"
    count=0
    while ! ip route get 1.1.1.1 >/dev/null 2>&1; do
        sleep 1
        count=$((count + 1))
        if [ $count -ge 30 ]; then
            echo "S40network: FAIL no default route after 30s"
            return 1
        fi
    done
    echo "S40network: default route up after ${count}s"

    # Step 2: /etc/resolv.conf populated (DNS configured).
    count=0
    while [ ! -s /etc/resolv.conf ]; do
        sleep 1
        count=$((count + 1))
        if [ $count -ge 10 ]; then
            echo "S40network: FAIL /etc/resolv.conf empty after 10s"
            return 1
        fi
    done

    # Step 3: DNS actually resolves a real name — exercises resolv.conf
    # AND the upstream resolver. nslookup is the busybox-portable test;
    # we resolve pool.ntp.org because that's literally the next caller's
    # target and a failure here predicts S49ntp's failure mode exactly.
    echo "S40network: verify DNS (nslookup pool.ntp.org)"
    count=0
    until nslookup pool.ntp.org >/dev/null 2>&1; do
        count=$((count + 1))
        if [ $count -ge 6 ]; then
            echo "S40network: FAIL DNS resolution failed after 6 tries"
            return 1
        fi
        sleep 2
    done
    echo "S40network: DNS OK after $count retries"

    # Step 4: ICMP reachability. No DNS, no TLS — confirms IP routing
    # actually delivers packets. 1.1.1.1 is chosen because it's stateless
    # and one of the most reachable hosts on the internet.
    echo "S40network: verify connectivity (ping 1.1.1.1)"
    count=0
    until ping -c 1 -W 3 1.1.1.1 >/dev/null 2>&1; do
        count=$((count + 1))
        if [ $count -ge 3 ]; then
            echo "S40network: FAIL ping 1.1.1.1 after 3 attempts"
            return 1
        fi
        sleep 2
    done
    echo "S40network: ping OK after $count retries"
    return 0
}

# Bounded-reboot recovery wrapper. Same pattern as S70sx1302: try the
# whole start_eth() sequence; on failure, reboot (counter on /data,
# capped at REBOOT_MAX). Trial-boot safety: don't reboot during a
# trial-boot OTA — the bootloader already owns rollback in that state
# and we'd race its bootcount machinery. After exhausting reboots:
# log loudly, exit 0, let init continue for SSH diagnosis (the device
# is then unable to OTA but at least reachable on the local LAN).
start_eth_with_recovery() {
    COUNTER=/data/.s40-reboots
    REBOOT_MAX=3

    if start_eth; then
        rm -f "$COUNTER"
        return 0
    fi

    logger -t S40network "verification failed — next steps would 100% fail"

    if [ "$(fw_printenv -n upgrade_available 2>/dev/null)" = "1" ]; then
        logger -t S40network "trial boot — leaving rollback to bootloader"
        return 0
    fi

    count=0
    [ -f "$COUNTER" ] && count=$(cat "$COUNTER" 2>/dev/null || echo 0)
    case "$count" in ''|*[!0-9]*) count=0 ;; esac

    if [ "$count" -ge "$REBOOT_MAX" ]; then
        logger -t S40network "FAIL after $REBOOT_MAX recovery reboots — leaving for SSH/OTA diagnosis"
        return 0
    fi

    count=$((count + 1))
    echo "$count" > "$COUNTER"
    sync
    logger -t S40network "rebooting to recover network ($count/$REBOOT_MAX)"
    sleep 5
    reboot
    return 0
}

stop_eth() {
    [ -f /var/run/udhcpc.eth0.pid ] && kill "$(cat /var/run/udhcpc.eth0.pid)" 2>/dev/null
    ifconfig eth0 down 2>/dev/null
}

case "$1" in
    start)
        start_lo
        start_eth_with_recovery
        ;;
    stop)
        stop_eth
        ;;
    restart)
        stop_eth
        sleep 1
        start_eth_with_recovery
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
