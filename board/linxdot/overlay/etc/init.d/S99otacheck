#!/bin/sh
# S99otacheck — kick off an OTA check in the background after boot settles.
# Non-blocking; the long sleep keeps it well clear of S98confirm's trial-boot
# health probe so the two don't race the upstream manifest.

case "$1" in
    start) ;;
    stop|*) exit 0 ;;
esac

(
    sleep 60
    /usr/sbin/ota-check 2>&1 | logger -t ota-boot
) &

exit 0
