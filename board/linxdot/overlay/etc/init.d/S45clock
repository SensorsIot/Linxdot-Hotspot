#!/bin/sh
#
# S45clock — bootstrap a sane wall-clock if the RTC is stale.
#
# The LD1001 has no battery-backed RTC, so on every power loss the kernel
# clock resets (we've observed it land at 2017-08-05). Any service that
# does TLS — basicstation's WSS to TTN, ota-check's HTTPS fetch from
# GitHub — fails with "certificate is not yet valid" until something
# steps the clock. ntpd is too slow for first-boot (and refuses to step
# jumps over ~1000 s without the `-g` flag), so we do a one-shot step
# from the HTTP `Date:` header of a known public endpoint.
#
# Runs after S40network (DHCP up) and before S60dockerd / S99otacheck so
# Docker containers and the OTA agent see a correct clock from the start.

set -e

SANE_MARKER=/var/run/clock-sane

step_from_http() {
    # Extract the Date: header from an HTTP HEAD response and feed it to
    # `date -u -s`. Plain HTTP is intentional: we're trying to fix the
    # clock so TLS validation can work afterwards.
    for url in http://github.com http://www.google.com; do
        http_date=$(curl -sSI --max-time 5 "$url" 2>/dev/null | awk '
            BEGIN { IGNORECASE = 1 }
            /^date:/ {
                sub(/^[Dd]ate:[[:space:]]*/, "")
                sub(/\r$/, "")
                print
                exit
            }')
        [ -n "$http_date" ] || continue
        if date -u -s "$http_date" >/dev/null 2>&1; then
            logger -t S45clock "clock set from ${url}: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
            return 0
        fi
    done
    return 1
}

case "$1" in
    start)
        # Already sane? Either a previous boot already stepped, or the
        # RTC happens to be reasonable.
        year=$(date -u +%Y)
        if [ "$year" -ge 2024 ]; then
            : > "$SANE_MARKER"
            exit 0
        fi
        if step_from_http; then
            : > "$SANE_MARKER"
            exit 0
        fi
        logger -t S45clock "warning: HTTP date fetch failed; clock left at $(date -u)"
        # Don't fail boot — basicstation will retry, ota-check next boot.
        ;;
    stop)
        rm -f "$SANE_MARKER"
        ;;
    *)
        echo "Usage: $0 {start|stop}" >&2
        exit 1
        ;;
esac

exit 0
