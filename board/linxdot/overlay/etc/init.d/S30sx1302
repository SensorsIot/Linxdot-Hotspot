#!/bin/sh
# S30sx1302 — bring up the SX1302 LoRa concentrator and verify it's
# operational before OTA + application start.
#
# Calls /usr/sbin/sx1302-reset which does the whole sequence (power +
# reset pulse + L1 chip ID + L2 register sweep + L3 write/readback).
# The script always exits 0 — even if the chip is dead or absent we
# want OTA (S60) to keep running so we can ship a fix. The application's
# /etc/ota/health-probe is the right place to escalate "chip not
# operational" into "refuse to commit slot" once an application is in
# the picture.

case "$1" in
    start) ;;
    stop|*) exit 0 ;;
esac

/usr/sbin/sx1302-reset || logger -t sx1302 "S30: chip bring-up failed"

exit 0
