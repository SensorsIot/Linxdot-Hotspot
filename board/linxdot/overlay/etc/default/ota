# OTA orchestration defaults.
#
# /data/ota.conf overrides these at boot if present (survives OTA updates
# since /data is never touched by the SWUpdate bundle).
#
# HEALTH_CHECK
#   full     (default) trial boot is committed only if the OTA path itself
#            still works end-to-end: default route present, clock-bootstrap
#            succeeds, and ota-check --dry-run reaches & parses the upstream
#            manifest. Guarantees the next OTA can land.
#   network  default route present + clock-bootstrap succeeds. Skip the
#            manifest fetch — useful if the upstream is temporarily
#            unreachable but networking is otherwise fine.
#   always   report healthy immediately. Dev/CI only — skips the real gate.
#   never    report unhealthy always. Forces U-Boot rollback on next bootcount
#            overflow; used for rollback tests.
#
# HEALTH_TIMEOUT
#   Seconds to wait for the healthy condition. Default 300 gives the
#   manifest fetch generous room for slow links or transient upstream
#   blips before forcing a rollback.
#
HEALTH_CHECK=full
HEALTH_TIMEOUT=300
