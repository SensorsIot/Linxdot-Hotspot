#!/bin/sh
# /usr/sbin/sx1302-reset — full bring-up of the SX1302 LoRa concentrator.
#
# Sequence per attempt:
#   1. Power rails: drop POWER+EXTRA to 0, settle, raise to 1.
#   2. Reset pulse: drive RESET high, settle, drive low (release).
#   3. Settle delay so the chip exits reset and is ready for SPI.
#   4. L1 chip ID:        read VERSION (0x5610), expect 0x10.
#   5. L2 register sweep: read several addresses, require ≥2 distinct
#                         values (catches stuck-bus failures where every
#                         read returns the same byte).
#   6. L3 write/readback: write a flipped pattern to a writable register
#                         (GPIO_DIR at 0x4203), read back, restore.
#                         Catches "read-only zombie" failure modes where
#                         the chip echoes hardcoded values but the
#                         internal state can't be mutated.
#
# Wrapped in a 3-attempt retry loop. Catches transient bring-up failures
# (slow GPIO settle, kernel-driver init order, bus enumeration race)
# without involving the init-system reboot machinery.
#
# Exit 0 = chip is electrically powered, SPI bus works in both directions,
# chip's internal logic is responsive (passed at least one of 3 attempts).
# Exit 1 = all 3 attempts failed; caller (S70sx1302) decides whether to
# escalate to a reboot.
#
# Adapted from the Linxdot vendor reset.sh (main branch). The OTA-only
# base owns the chip directly — no docker, no basicstation context.

set -u

# ── GPIOs (RK3566 sysfs numbering, see Docs/Hardware.md) ────────────────
POWER_GPIO=23     # primary 3v3 LDO enable
EXTRA_GPIO=17     # secondary rail (Linxdot dual-rail design)
RESET_GPIO=15     # chip reset (active high pulse, drop low to release)

# ── SPI ─────────────────────────────────────────────────────────────────
SPIDEV=${SPIDEV:-/dev/spidev0.0}
SPI_SPEED=${SPI_SPEED:-1000000}    # 1 MHz; SX1302 supports up to 8 MHz

# ── SX1302 register addresses (sx1302_hal/libloragw/src/sx1302.h) ───────
REG_VERSION=0x5610      # read-only chip ID, expected 0x10
REG_GPIO_DIR=0x4203     # writable, used for L3 write/readback
EXPECTED_VERSION=10     # hex string from od

# ── Retry budget ────────────────────────────────────────────────────────
ATTEMPT_MAX=3

log()    { echo "sx1302-reset: $*"; logger -t sx1302 "$*" 2>/dev/null || true; }
warn()   { log "WARN $*"; }
giveup() { log "FAIL $*"; return 1; }

# ── GPIO helpers ────────────────────────────────────────────────────────
export_gpio() {
    pin=$1
    if [ ! -d "/sys/class/gpio/gpio$pin" ]; then
        echo "$pin" > /sys/class/gpio/export 2>/dev/null \
            || { warn "cannot export gpio$pin"; return 1; }
    fi
    [ -d "/sys/class/gpio/gpio$pin" ] || { warn "gpio$pin missing after export"; return 1; }
    echo out > "/sys/class/gpio/gpio$pin/direction" \
        || { warn "cannot set gpio$pin direction=out"; return 1; }
}
write_gpio()  {
    echo "$2" > "/sys/class/gpio/gpio$1/value" \
        || { warn "cannot write gpio$1=$2"; return 1; }
}
verify_gpio() {
    actual=$(cat "/sys/class/gpio/gpio$1/value" 2>/dev/null) \
        || { warn "cannot read gpio$1"; return 1; }
    [ "$actual" = "$2" ] || { warn "gpio$1 readback=$actual, expected $2"; return 1; }
}

# ── SPI helpers ─────────────────────────────────────────────────────────
# Emit a single byte (0-255) as raw output. Uses awk so we can compute
# values numerically without printf-format tricks that break under busybox.
byte() { awk -v n="$1" 'BEGIN { printf "%c", n }'; }

# Read 1 byte from a 16-bit register address. Echoes 2 hex chars.
spi_read() {
    addr=$1
    ah=$(( (addr >> 8) & 0x7F ))    # high byte, MSB clear (read)
    al=$(( addr & 0xFF ))
    rx=$( ( byte 0; byte "$ah"; byte "$al"; byte 0; byte 0 ) \
          | spi-pipe -d "$SPIDEV" -s "$SPI_SPEED" \
          | od -An -tx1 | tr -d ' \n')
    [ "${#rx}" -eq 10 ] || { warn "spi_read($addr): got $((${#rx} / 2)) bytes, want 5"; return 1; }
    echo "${rx#????????}"            # last byte = register value
}

# Write 1 byte to a 16-bit register address.
spi_write() {
    addr=$1; val=$2
    ah=$(( ((addr >> 8) & 0x7F) | 0x80 ))    # high byte, MSB set (write)
    al=$(( addr & 0xFF ))
    ( byte 0; byte "$ah"; byte "$al"; byte 0; byte "$val" ) \
        | spi-pipe -d "$SPIDEV" -s "$SPI_SPEED" >/dev/null \
        || { warn "spi_write($addr=$val) failed"; return 1; }
}

# ── One full bring-up attempt ───────────────────────────────────────────
try_once() {
    attempt=$1

    # Step 1 — power rails
    export_gpio "$POWER_GPIO" || return 1
    export_gpio "$EXTRA_GPIO" || return 1
    export_gpio "$RESET_GPIO" || return 1

    write_gpio "$POWER_GPIO" 0 || return 1
    write_gpio "$EXTRA_GPIO" 0 || return 1
    sleep 1
    write_gpio "$POWER_GPIO" 1 || return 1
    write_gpio "$EXTRA_GPIO" 1 || return 1
    sleep 1

    # Step 2 — reset pulse
    write_gpio "$RESET_GPIO" 1 || return 1
    sleep 0.1
    write_gpio "$RESET_GPIO" 0 || return 1
    sleep 0.1

    verify_gpio "$POWER_GPIO" 1 || return 1
    verify_gpio "$EXTRA_GPIO" 1 || return 1
    verify_gpio "$RESET_GPIO" 0 || return 1

    # Step 3 — settle + sanity-check tools/paths
    sleep 0.1
    [ -c "$SPIDEV" ] || { warn "$SPIDEV not present"; return 1; }
    command -v spi-pipe >/dev/null 2>&1 || { warn "spi-pipe not on PATH"; return 1; }

    # Step 4 — L1 chip ID
    ver=$(spi_read $REG_VERSION) || return 1
    if [ "$ver" != "$EXPECTED_VERSION" ]; then
        warn "attempt $attempt: chip ID = 0x$ver, expected 0x$EXPECTED_VERSION"
        return 1
    fi

    # Step 5 — L2 register sweep
    sweep=""
    for a in 0x5610 0x5611 0x5604 0x5614 0x5615 0x4203; do
        v=$(spi_read $a) || return 1
        sweep="$sweep $v"
    done
    distinct=$(echo $sweep | tr ' ' '\n' | sort -u | wc -l)
    if [ "$distinct" -lt 2 ]; then
        warn "attempt $attempt: register sweep stuck ($sweep)"
        return 1
    fi

    # Step 6 — L3 write/readback on GPIO_DIR
    orig_hex=$(spi_read $REG_GPIO_DIR) || return 1
    orig=$(( 0x$orig_hex ))
    test_val=$(( orig ^ 0x55 ))
    test_hex=$(printf '%02x' $test_val)
    spi_write $REG_GPIO_DIR $test_val || return 1
    got=$(spi_read $REG_GPIO_DIR) || return 1
    spi_write $REG_GPIO_DIR $orig || return 1
    if [ "$got" != "$test_hex" ]; then
        warn "attempt $attempt: write/readback (orig=0x$orig_hex wrote=0x$test_hex got=0x$got)"
        return 1
    fi

    log "attempt $attempt OK (chip ID=0x$ver, sweep distinct=$distinct, write/readback OK)"
    return 0
}

# ── Retry loop ──────────────────────────────────────────────────────────
attempt=1
while [ "$attempt" -le "$ATTEMPT_MAX" ]; do
    log "attempt $attempt/$ATTEMPT_MAX"
    if try_once "$attempt"; then
        log "OK SX1302 fully operational"
        exit 0
    fi
    attempt=$((attempt + 1))
    [ "$attempt" -le "$ATTEMPT_MAX" ] && sleep 2
done

giveup "SX1302 not operational after $ATTEMPT_MAX attempts"
exit 1
