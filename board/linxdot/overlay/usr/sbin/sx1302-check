#!/bin/sh
# /usr/sbin/sx1302-check — read the SX1302 version register over SPI and
# verify it matches the expected chip ID. Run AFTER sx1302-power has
# applied power + pulsed reset; the chip needs a few hundred microseconds
# to come out of reset before SPI is responsive.
#
# SPI protocol per Semtech sx1302_hal/libloragw/src/loragw_spi.c::lgw_spi_r:
#   tx[0] = SPI_RW_NONE | spi_mux_target  (0x00 = read, mux=concentrator)
#   tx[1] = (addr >> 8) & 0x7F            (high address byte, read bit clear)
#   tx[2] = (addr     ) & 0xFF            (low address byte)
#   tx[3] = 0x00                          (dummy)
#   tx[4] = 0x00                          (data byte slot, returns reg value)
#
# Version register VERSION_ADDR = 0x5610 returns 0x10 for SX1302.

set -eu

SPIDEV=${SPIDEV:-/dev/spidev0.0}
SPI_SPEED=${SPI_SPEED:-1000000}           # 1 MHz; SX1302 supports up to 8 MHz
EXPECTED_VERSION=10                       # hex string from od

log()  { echo "sx1302-check: $*"; logger -t sx1302 "$*" 2>/dev/null || true; }
fail() { log "FAIL $*"; exit 1; }

[ -c "$SPIDEV" ] || fail "$SPIDEV not present (kernel didn't expose spidev?)"
command -v spi-pipe >/dev/null 2>&1 || fail "spi-pipe not on PATH (BR2_PACKAGE_SPI_TOOLS=y?)"

# Build the 5-byte read transaction in-line via printf, pipe straight into
# spi-pipe so the raw bytes don't go through a shell variable (NUL-safe).
# Output is 5 bytes; we hexify with od and concatenate to one 10-char string.
rx=$(printf '\000\126\020\000\000' | spi-pipe -d "$SPIDEV" -s "$SPI_SPEED" \
     | od -An -tx1 | tr -d ' \n')

[ "${#rx}" -eq 10 ] || fail "got $((${#rx} / 2)) bytes from SPI, expected 5: rx=$rx"

ver=${rx#????????}                         # last 2 hex chars = byte at rx[4]
log "version register 0x5610 = 0x$ver (full rx=$rx)"

if [ "$ver" = "$EXPECTED_VERSION" ]; then
    log "OK chip is alive"
    exit 0
fi

fail "version=0x$ver, expected 0x$EXPECTED_VERSION — chip not responding correctly"
