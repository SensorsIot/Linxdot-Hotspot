#!/bin/sh
# /usr/sbin/sx1302-power — power-on sequence for the LD1001's SX1302
# LoRa concentrator. Adapted from the Linxdot vendor reset.sh; drops the
# docker / basicstation context since the OTA-only base owns nothing
# above the chip.
#
# GPIOs (RK3566 sysfs numbering, see Docs/Hardware.md):
#   POWER_GPIO=23  primary 3v3 LDO enable for vcc3v3-lora
#   EXTRA_GPIO=17  secondary rail (Linxdot dual-rail design)
#   RESET_GPIO=15  chip reset (active high pulse, then drop low to release)
#
# Exit 0 = power applied, GPIO readback verified.
# Exit non-zero = sysfs writes failed or readback didn't match commanded value.

set -eu

POWER_GPIO=23
EXTRA_GPIO=17
RESET_GPIO=15

log()   { echo "sx1302-power: $*"; logger -t sx1302 "$*" 2>/dev/null || true; }
fatal() { log "FATAL $*"; exit 1; }

export_gpio() {
    pin=$1
    if [ ! -d "/sys/class/gpio/gpio$pin" ]; then
        echo "$pin" > /sys/class/gpio/export 2>/dev/null \
            || fatal "cannot export gpio$pin (sysfs busy or kernel rejected)"
    fi
    [ -d "/sys/class/gpio/gpio$pin" ] || fatal "gpio$pin missing after export"
    echo out > "/sys/class/gpio/gpio$pin/direction" \
        || fatal "cannot set gpio$pin direction=out"
}

write_gpio() {
    pin=$1; val=$2
    echo "$val" > "/sys/class/gpio/gpio$pin/value" \
        || fatal "cannot write gpio$pin=$val"
}

verify_gpio() {
    pin=$1; expected=$2
    actual=$(cat "/sys/class/gpio/gpio$pin/value") || fatal "cannot read gpio$pin"
    [ "$actual" = "$expected" ] \
        || fatal "gpio$pin readback=$actual, expected $expected"
}

log "powering on SX1302 (POWER=$POWER_GPIO EXTRA=$EXTRA_GPIO RESET=$RESET_GPIO)"
export_gpio "$POWER_GPIO"
export_gpio "$EXTRA_GPIO"
export_gpio "$RESET_GPIO"

# Power rails up first, then a brief reset pulse to bring the chip out of
# reset into a known state. Match the timings from main's reset.sh — those
# have been validated against real hardware.
write_gpio "$POWER_GPIO" 1
write_gpio "$EXTRA_GPIO" 1
sleep 1

write_gpio "$RESET_GPIO" 1
sleep 0.1
write_gpio "$RESET_GPIO" 0
sleep 0.1

verify_gpio "$POWER_GPIO" 1
verify_gpio "$EXTRA_GPIO" 1
verify_gpio "$RESET_GPIO" 0
log "OK power=1 extra=1 reset=0"
