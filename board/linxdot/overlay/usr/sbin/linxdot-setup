#!/bin/sh
# /usr/sbin/linxdot-setup — interactive provisioning wizard.
#
# Walks the operator through the steps required to take a freshly-flashed
# OpenLinxdot device from "boots and gets a fallback IP" to "talking to
# TTN with a unit-correct MAC".
#
# Phase A: bind the case sticker MAC to eth0.
# Phase B: read Gateway EUI, walk through TTN registration, install LNS key,
#          verify the MUXS handshake.
#
# State is tracked in /data/.setup-state, which survives OTA and rollback.
# Re-running the wizard at any time picks up where it left off.

set -eu

STATE_FILE=/data/.setup-state
SETUP_MAC="02:00:5d:01:01:01"
TC_KEY=/data/basicstation/tc_key.txt
EUI_TIMEOUT=60
MUXS_TIMEOUT=60

read_state() {
    cat "$STATE_FILE" 2>/dev/null || echo fresh
}

write_state() {
    mkdir -p "$(dirname "$STATE_FILE")"
    printf '%s\n' "$1" > "$STATE_FILE"
}

print_banner() {
    cat <<'EOF'

================================================================
                  OpenLinxdot Setup Wizard
================================================================

EOF
}

print_status() {
    mac=$(cat /sys/class/net/eth0/address 2>/dev/null || echo "(unknown)")
    ip4=$(ifconfig eth0 2>/dev/null | sed -n 's/.*inet addr:\([0-9.]*\).*/\1/p')
    state=$(read_state)
    printf "  eth0 MAC : %s\n" "$mac"
    printf "  IP       : %s\n" "${ip4:-(none)}"
    printf "  State    : %s\n\n" "$state"
}

ask() {
    # ask "prompt" — reads a non-empty line from stdin, echoes the value.
    # Prompt goes to stderr so callers can capture only the answer via $().
    while :; do
        printf '%s' "$1" >&2
        read answer || exit 1
        [ -n "$answer" ] && { printf '%s' "$answer"; return; }
    done
}

confirm() {
    # confirm "prompt [Y/n]" — yes-default. Returns 0 for yes, 1 for no.
    printf '%s ' "$1"
    read answer || return 1
    case "$answer" in
        n|N|no|NO) return 1 ;;
        *) return 0 ;;
    esac
}

prompt_retry() {
    # After an actionable error, ask the user to fix and continue. Returns
    # 0 on retry (caller should `continue`), 1 if the user wants to abort.
    printf '\nFix the issue above, then press Enter to retry (type "abort" to give up): ' >&2
    read answer || return 1
    case "$answer" in abort|ABORT|quit|exit|q|Q) return 1 ;; esac
    return 0
}

normalize_mac() {
    # Lower-case, accept either ':' or '-' separators, output canonical
    # aa:bb:cc:dd:ee:ff. Echoes nothing on bad input.
    in=$(printf '%s' "$1" | tr 'A-F-' 'a-f:')
    case "$in" in
        [0-9a-f][0-9a-f]:[0-9a-f][0-9a-f]:[0-9a-f][0-9a-f]:[0-9a-f][0-9a-f]:[0-9a-f][0-9a-f]:[0-9a-f][0-9a-f])
            printf '%s' "$in"
            ;;
    esac
}

phase_a() {
    cat <<EOF
Step 1 of 2: Bind the unit's MAC address
-----------------------------------------

The eth0 interface is currently using the shared setup MAC
$SETUP_MAC. Every fresh OpenLinxdot device announces this
address — useful for finding the device on your router, but not
the unit's real identity. Bind the unique MAC printed on the case
sticker now: it's globally-unique and assigned to this unit only.

EOF

    while :; do
        raw=$(ask "Enter the MAC printed on the case (e.g. 0c:86:29:e0:22:7d): ")
        mac=$(normalize_mac "$raw")
        if [ -n "$mac" ]; then
            break
        fi
        echo "  Bad format — expected aa:bb:cc:dd:ee:ff or aa-bb-cc-dd-ee-ff" >&2
    done

    echo
    printf "Bind eth0 to %s? [Y/n] " "$mac"
    read confirm_answer || exit 1
    case "$confirm_answer" in
        n|N|no|NO) echo "Aborted, no change made."; exit 1 ;;
    esac

    echo
    if ! /usr/sbin/set-eth-mac "$mac"; then
        echo
        echo "set-eth-mac failed. Setup state not changed."
        exit 1
    fi

    write_state mac-bound

    cat <<EOF

================================================================
 Step 1 done.
================================================================

The MAC is now stored in /dev/mmcblk1boot0 — it survives reboots,
OTA updates, and any future rkdeveloptool re-flash.

What happens next:
  1. The device reboots in 3 seconds.
  2. Your SSH session will drop. Wait ~90 s, then look for this
     MAC in your router's DHCP table:
         $mac
  3. SSH back in at the new IP and run 'linxdot-setup' again to
     finish TTN registration.

EOF
    sleep 3
    reboot
}

read_gateway_eui() {
    # Bootstrap basicstation with a placeholder key so it prints the EUI,
    # then poll its logs for up to EUI_TIMEOUT seconds. Echoes the EUI on
    # success (16 hex chars), nothing on timeout.
    mkdir -p "$(dirname "$TC_KEY")"
    if [ ! -s "$TC_KEY" ]; then
        echo placeholder > "$TC_KEY"
    fi
    /etc/init.d/S80dockercompose start >/dev/null 2>&1 || true

    i=0
    while [ "$i" -lt "$EUI_TIMEOUT" ]; do
        # Extract exactly 16 hex chars after "Gateway EUI:" (handles ANSI
        # colour codes / trailing whitespace that basicstation may emit).
        eui=$(docker logs basicstation 2>&1 \
            | sed -n 's/.*Gateway EUI: *\([0-9A-Fa-f]\{16\}\).*/\1/p' \
            | head -1)
        if [ -n "$eui" ]; then
            printf '%s' "$eui"
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

wait_for_muxs() {
    # Poll basicstation logs for the MUXS handshake message.
    # Returns 0 on success, 1 on timeout.
    i=0
    while [ "$i" -lt "$MUXS_TIMEOUT" ]; do
        if docker logs basicstation 2>&1 | grep -q "Connected to MUXS"; then
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    return 1
}

# ---- TTN REST helpers -----------------------------------------------------
# Globals set during phase_b: TTN_API_KEY, TTN_CLUSTER. After every ttn_request
# call: HTTP_STATUS holds the HTTP code, TTN_RESPONSE holds the body.
#
# Note: function output is NOT captured via $() because that would spawn a
# subshell, and the HTTP_STATUS / TTN_RESPONSE assignments inside it would
# not propagate back to the caller. Globals stay in the parent shell.

HTTP_STATUS=000
TTN_RESPONSE=
LNS_KEY_OVERRIDE=

ttn_request() {
    # ttn_request METHOD PATH [BODY]
    method=$1; path=$2; body=${3:-}
    body_file=$(mktemp)
    if [ -n "$body" ]; then
        HTTP_STATUS=$(curl -sS \
            -X "$method" \
            -H "Authorization: Bearer ${TTN_API_KEY}" \
            -H "Content-Type: application/json" \
            -d "$body" \
            -o "$body_file" \
            -w '%{http_code}' \
            "https://${TTN_CLUSTER}.cloud.thethings.network${path}" 2>/dev/null) || HTTP_STATUS=000
    else
        HTTP_STATUS=$(curl -sS \
            -X "$method" \
            -H "Authorization: Bearer ${TTN_API_KEY}" \
            -o "$body_file" \
            -w '%{http_code}' \
            "https://${TTN_CLUSTER}.cloud.thethings.network${path}" 2>/dev/null) || HTTP_STATUS=000
    fi
    TTN_RESPONSE=$(cat "$body_file")
    rm -f "$body_file"
}

json_str() {
    # json_str FIELD < input — extract first matching "FIELD":"VALUE".
    field=$1
    tr -d '\n' | sed -n "s|.*\"${field}\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*|\\1|p"
}

eui_to_id() {
    # 0016C001F140B34D -> linxdot-0016c001f140b34d
    printf 'linxdot-%s' "$(printf '%s' "$1" | tr 'A-F' 'a-f')"
}

cluster_freqplan_default() {
    case "$1" in
        eu1)  echo "EU_863_870" ;;
        nam1) echo "US_902_928_FSB_2" ;;
        au1)  echo "AU_915_928_FSB_2" ;;
        as1)  echo "AS_923_TTN" ;;
        *)    echo "EU_863_870" ;;
    esac
}

find_gateway_by_eui() {
    # Search the owner's existing gateways for one matching $eui.
    # Sets the global $existing_gid (empty if no match). Opportunistic:
    # if the API key lacks the LIST right we silently return empty and
    # the caller falls through to the create-and-handle-409 path.
    existing_gid=
    ttn_request GET "/api/v3/${owner_path}/gateways?field_mask=ids&limit=1000"
    [ "$HTTP_STATUS" = 200 ] || return 0

    eui_uc=$(printf '%s' "$eui" | tr 'a-f' 'A-F')
    eui_lc=$(printf '%s' "$eui" | tr 'A-F' 'a-f')
    # TTS serializes ids as {"gateway_id":"...","eui":"..."} compactly with
    # no whitespace and gateway_id first (proto field 1 vs 2). Match either
    # case for the EUI value.
    for pat in \
        "\"gateway_id\":\"[^\"]*\",\"eui\":\"$eui_uc\"" \
        "\"gateway_id\":\"[^\"]*\",\"eui\":\"$eui_lc\""; do
        existing_gid=$(printf '%s' "$TTN_RESPONSE" \
            | grep -oE "$pat" \
            | head -1 \
            | sed -n 's/.*"gateway_id":"\([^"]*\)".*/\1/p')
        [ -n "$existing_gid" ] && return 0
    done
}

resolve_gateway_conflict() {
    # Called after POST gateway returns 409. TTN's error body includes
    # `details[].attributes.gateway_id` naming the existing gateway, so
    # we extract that directly instead of scanning. Outcomes:
    #   1. Existing gateway has our EUI and we own it → silently reuse,
    #      adopting the existing gateway_id (which may differ from the
    #      one the operator typed if 409 was eui_taken vs id_taken).
    #   2. Existing gateway has a different EUI than ours → unexpected
    #      (TTN attribute should match) → hard error.
    #   3. We can't access the existing gateway (403) → it belongs to
    #      another tenant. Show the operator the existing gid + admin
    #      contact and let them paste an LNS key for it.
    #   4. Existing gateway disappeared between POST and GET (404) →
    #      transient, ask the operator to retry.
    msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
    existing_gid=$(printf '%s' "$TTN_RESPONSE" | json_str gateway_id)
    contact=$(printf '%s' "$TTN_RESPONSE" | json_str administrative_contact)
    [ -z "$existing_gid" ] && existing_gid=$gid   # fallback if TTN omits it

    echo "  conflict — TTN reports existing gateway '$existing_gid'." >&2
    [ -n "$contact" ] && [ "$contact" != "$owner" ] && echo "  admin contact: $contact" >&2
    [ -n "$msg" ] && echo "  TTN says: $msg" >&2

    ttn_request GET "/api/v3/gateways/${existing_gid}?field_mask=ids,name"
    case "$HTTP_STATUS" in
        200)
            existing_eui=$(printf '%s' "$TTN_RESPONSE" | json_str eui)
            existing_eui_uc=$(printf '%s' "$existing_eui" | tr 'a-f' 'A-F')
            if [ "$existing_eui_uc" = "$eui" ]; then
                if [ "$existing_gid" != "$gid" ]; then
                    echo "  Adopting existing gateway_id '$existing_gid' (you typed '$gid')." >&2
                else
                    echo "  Reusing existing gateway '$existing_gid' (same EUI as this device)." >&2
                fi
                gid=$existing_gid
                return 0
            fi
            cat >&2 <<EOF
  TTN flagged '$existing_gid' as the conflicting gateway, but a
  follow-up GET shows it has EUI $existing_eui (not $eui). This is
  unexpected. Re-run linxdot-setup with a different gateway_id, or
  open an issue against linxdot-setup.
EOF
            exit 1
            ;;
        403)
            cat >&2 <<EOF

  This LoRaWAN EUI is registered on TTN as gateway:

      $existing_gid${contact:+
      admin contact: $contact}

  Your bootstrap API key cannot manage that gateway (HTTP 403),
  so the wizard cannot create an LNS key for it via REST.

  Options:
    A) If YOU own that registration under a different tenant or
       organization, switch to that owner's API key and re-run
       linxdot-setup.
    B) Paste an existing LNS key for that gateway. To make one,
       open the gateway page in TTN Console (you'll need access)
       and add a key with "Link as Gateway" right.

EOF
            gid=$existing_gid   # so the success summary names the real gid
            prompt_for_lns_key "blank to abort"
            ;;
        404)
            cat >&2 <<EOF
  TTN reported '$existing_gid' as the conflicting gateway, but a
  follow-up GET shows it doesn't exist. Likely a transient state.
  Re-run linxdot-setup in a moment.
EOF
            exit 1
            ;;
        *)
            echo "  Unexpected lookup status: HTTP $HTTP_STATUS" >&2
            echo "  TTN says: $(printf '%s' "$TTN_RESPONSE" | json_str message)" >&2
            exit 1
            ;;
    esac
}

prompt_for_lns_key() {
    # prompt_for_lns_key HINT — sets $LNS_KEY_OVERRIDE.
    while :; do
        manual_key=$(ask "Paste LNS API key (NNSXS.…)${1:+, $1}: " || true)
        if [ -z "${manual_key:-}" ]; then
            echo "Aborted." >&2
            exit 1
        fi
        case "$manual_key" in
            NNSXS.*)
                if [ "${#manual_key}" -ge 32 ]; then
                    LNS_KEY_OVERRIDE=$manual_key
                    return 0
                fi
                echo "  too short — TTN keys are typically 80+ chars." >&2
                ;;
            *) echo "  bad format — must start with 'NNSXS.'" >&2 ;;
        esac
    done
}

ask_lns_for_known_gateway() {
    # We KNOW $gid is the right gateway (just created or reused via 409),
    # but auto-create of the LNS key failed (e.g. bootstrap key lacks
    # RIGHT_GATEWAY_SETTINGS_API_KEYS). Direct the operator to a clickable
    # URL for THIS gateway.
    msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
    cat >&2 <<EOF

  Could not auto-create the LNS key for '$gid' (HTTP $HTTP_STATUS):
      TTN says: ${msg:-(no message)}

  Open this URL in a browser to create one manually:

      https://${TTN_CLUSTER}.cloud.thethings.network/console/gateways/${gid}/api-keys

  Click "+ Add API key", name it (e.g. "openlinxdot-lns"), tick
  "Link as Gateway to a Gateway Server for traffic exchange",
  click Create, copy the NNSXS.… value.

EOF
    prompt_for_lns_key "blank to abort"
}

# ---- Phase B: TTN auto-provisioning ---------------------------------------

phase_b() {
    cat <<EOF
Step 2 of 2: Connect to The Things Network
-------------------------------------------

This step talks to TTN over HTTPS to register your gateway and
create an LNS key automatically. You only have to paste one TTN
admin API key — the wizard does the rest.

EOF

    printf "Reading Gateway EUI (up to %d s)…\n" "$EUI_TIMEOUT"
    if ! eui=$(read_gateway_eui) || [ -z "$eui" ]; then
        cat <<EOF

ERROR: Could not read the Gateway EUI from basicstation logs in
${EUI_TIMEOUT}s. Inspect the container manually:
    docker logs basicstation 2>&1 | tail -30
Re-run 'linxdot-setup' once basicstation is healthy. State left
at 'mac-bound'.

EOF
        exit 1
    fi

    cat <<EOF

  Gateway EUI: $eui

EOF

    # ---- Credential collection + validation, all in one retry loop ------
    # The user can fix typos / cluster / key / rights and continue without
    # re-running the wizard. We selectively clear inputs to force re-prompt
    # of just the bit that's wrong; on permission fixes (which take effect
    # immediately on the same key) we keep the inputs and just re-validate.
    TTN_CLUSTER=
    owner=
    owner_kind=
    TTN_API_KEY=

    while :; do
        # Cluster
        if [ -z "$TTN_CLUSTER" ]; then
            cat <<'EOF'
Which TTN cluster do you use?
  1) eu1   (Europe — default)
  2) nam1  (North America)
  3) au1   (Australia)
  4) as1   (Asia)
EOF
            while :; do
                printf 'Cluster [1-4, default 1]: ' >&2
                read choice || exit 1
                case "${choice:-1}" in
                    1|eu1)  TTN_CLUSTER=eu1;  break ;;
                    2|nam1) TTN_CLUSTER=nam1; break ;;
                    3|au1)  TTN_CLUSTER=au1;  break ;;
                    4|as1)  TTN_CLUSTER=as1;  break ;;
                    *) echo "  invalid choice" >&2 ;;
                esac
            done
        fi

        # Owner (user/org)
        if [ -z "$owner" ]; then
            while :; do
                owner=$(ask "TTN user or organization ID: ")
                case "$owner" in
                    [a-z0-9][a-z0-9_-]*) break ;;
                    *) echo "  TTN IDs are lowercase letters/digits, '-' or '_'." >&2; owner= ;;
                esac
            done
            printf 'Is "%s" a user or an organization? [u/o, default u]: ' "$owner" >&2
            read owner_kind || exit 1
            : "${owner_kind:=u}"
        fi
        case "$owner_kind" in
            o|O|org|Org|ORG) owner_path="organizations/${owner}";
                             collab='"organization_ids":{"organization_id":"'"$owner"'"}'
                             owner_label=organization ;;
            *)               owner_path="users/${owner}"
                             collab='"user_ids":{"user_id":"'"$owner"'"}'
                             owner_label=user ;;
        esac

        # API key. Accept any pasted blob — extract the NNSXS.<token>.
        if [ -z "$TTN_API_KEY" ]; then
            while :; do
                raw=$(ask "Paste your TTN admin API key: ")
                TTN_API_KEY=$(printf '%s' "$raw" | grep -oE 'NNSXS\.[A-Z0-9.]+' | head -1)
                if [ -n "$TTN_API_KEY" ] && [ "${#TTN_API_KEY}" -ge 32 ]; then
                    break
                fi
                echo "  Couldn't find an NNSXS.<key> in the pasted text. Try again." >&2
                TTN_API_KEY=
            done
        fi

        # Validate: auth_info checks key + cluster. Print "OK" only after
        # the follow-up rights check also passes (single line covers both).
        printf "Verifying API key against %s.cloud.thethings.network… " "$TTN_CLUSTER" >&2
        ttn_request GET /api/v3/auth_info
        case "$HTTP_STATUS" in
            200) ;;
            000)
                echo
                cat >&2 <<EOF
ERROR: could not reach TTN at ${TTN_CLUSTER}.cloud.thethings.network.

What to do:
  1. Check the device has internet (curl -sI https://github.com).
  2. If you got 'certificate not yet valid', run /usr/sbin/clock-bootstrap.
EOF
                prompt_retry || exit 1
                continue
                ;;
            400|401|403)
                echo
                msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
                cat >&2 <<EOF
ERROR: TTN rejected the API key (HTTP $HTTP_STATUS).
  TTN says: ${msg:-(no message)}

What to do:
  Either the cluster is wrong or the key is bad/expired. Get a fresh key:
    https://${TTN_CLUSTER}.cloud.thethings.network/console → profile
    (top right) → Personal API keys → Add API key → tick "Manage
    gateways" → Create.
EOF
                TTN_API_KEY=         # re-prompt key
                TTN_CLUSTER=         # let user pick a different cluster too
                prompt_retry || exit 1
                continue
                ;;
            *)
                echo
                msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
                cat >&2 <<EOF
ERROR: TTN responded with HTTP $HTTP_STATUS.
  TTN says: ${msg:-(no message)}
EOF
                prompt_retry || exit 1
                continue
                ;;
        esac

        # Validate: API key has the right needed for gateway-create.
        rights=$(printf '%s' "$TTN_RESPONSE" | tr -d '\n' \
            | sed -n 's|.*"rights"[[:space:]]*:[[:space:]]*\[\([^]]*\)\].*|\1|p' \
            | tr -d '" ')
        case "$owner_kind" in
            o|O|org|Org|ORG) needed=RIGHT_ORGANIZATION_GATEWAYS_CREATE ;;
            *)               needed=RIGHT_USER_GATEWAYS_CREATE ;;
        esac
        case ",$rights," in
            *,RIGHT_ALL,*|*,"$needed",*)
                echo "OK (has $needed)" >&2
                ;;
            *)
                echo
                cat >&2 <<EOF
ERROR: this API key is missing $needed.
EOF
                if [ -n "$rights" ]; then
                    echo "  Key currently has:" >&2
                    printf '%s' "$rights" | tr ',' '\n' | sed 's/^/    /' >&2
                else
                    echo "  Key currently has no rights." >&2
                fi
                cat >&2 <<EOF

What to do:
  Open https://${TTN_CLUSTER}.cloud.thethings.network/console → profile
  (top right) → Personal API keys → click your key → tick "Manage
  gateways" → Save. (The change takes effect immediately on the same key.)
EOF
                prompt_retry || exit 1
                continue   # keep TTN_API_KEY — same key, fresher rights
                ;;
        esac

        # Validate: owner exists + key can list its gateways. Doubles as
        # the "is this device already registered?" check.
        printf "Checking TTN for an existing registration of EUI %s… " "$eui" >&2
        find_gateway_by_eui
        case "$HTTP_STATUS" in
            200) break ;;   # success — exit input-collection loop
            401|403)
                echo
                cat >&2 <<EOF
ERROR: API key can't list gateways under $owner_label '$owner' (HTTP $HTTP_STATUS).

What to do:
  1. Check '$owner' is spelled correctly (TTN IDs are case-sensitive).
  2. If the spelling is right, tick "Manage gateways" in the TTN console
     (the change takes effect immediately).
EOF
                owner=               # re-prompt owner
                prompt_retry || exit 1
                continue
                ;;
            404)
                echo
                cat >&2 <<EOF
ERROR: $owner_label '$owner' does not exist on TTN.

What to do: check the spelling — your handle is the segment after
/users/ in the TTN console URL once you're signed in.
EOF
                owner=               # re-prompt owner
                prompt_retry || exit 1
                continue
                ;;
            *)
                echo
                msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
                cat >&2 <<EOF
ERROR: TTN returned HTTP $HTTP_STATUS while listing gateways.
  TTN says: ${msg:-(no message)}
EOF
                prompt_retry || exit 1
                continue
                ;;
        esac
    done

    if [ -n "$existing_gid" ]; then
        echo "found '$existing_gid'." >&2
        gid=$existing_gid
    else
        echo "none — will register a new one." >&2

        # Gateway ID
        default_id=$(eui_to_id "$eui")
        while :; do
            printf 'Gateway name [default %s]: ' "$default_id" >&2
            read gid || exit 1
            gid=${gid:-$default_id}
            case "$gid" in
                [a-z][a-z0-9_-]*[a-z0-9]) break ;;
                *) echo "  start with a lowercase letter, then [a-z0-9_-], end alphanumeric" >&2 ;;
            esac
        done

        # Frequency plan
        default_fp=$(cluster_freqplan_default "$TTN_CLUSTER")
        printf 'Frequency plan [default %s]: ' "$default_fp" >&2
        read fp || exit 1
        fp=${fp:-$default_fp}

        cat <<EOF

  Cluster      : $TTN_CLUSTER
  Owner        : $owner ($owner_path)
  Gateway name : $gid
  Gateway EUI  : $eui
  Freq. plan   : $fp

EOF
        printf 'Create this gateway on TTN? [Y/n] ' >&2
        read go || exit 1
        case "$go" in n|N|no|NO) echo "Aborted." >&2; exit 1 ;; esac

        body=$(printf '{"gateway":{"ids":{"gateway_id":"%s","eui":"%s"},"name":"%s","frequency_plan_id":"%s","enforce_duty_cycle":true,"status_public":true},"collaborator":{%s}}' \
            "$gid" "$eui" "$gid" "$fp" "$collab")
        printf "Registering '%s' on TTN… " "$gid" >&2
        ttn_request POST "/api/v3/${owner_path}/gateways" "$body"
        case "$HTTP_STATUS" in
            200|201) echo "OK" >&2 ;;
            409)
                # Pre-check missed it — typically means the EUI is owned
                # by a DIFFERENT tenant (find_gateway_by_eui only looks
                # under the current owner). Fall through to the existing
                # cross-tenant resolver.
                echo >&2
                resolve_gateway_conflict
                ;;
            401|403)
                echo >&2
                msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
                cat >&2 <<EOF
ERROR: the API key can't create gateways under '$owner'.
  TTN says: ${msg:-(no message)}

What to do:
  1. Open https://${TTN_CLUSTER}.cloud.thethings.network → profile (top
     right) → Personal API keys → click your provisioning key.
  2. Under "Gateways", tick "Manage gateways" (or at minimum
     "Create gateways under the user account").
  3. Save. Re-run linxdot-setup with the same key — the change takes
     effect immediately.
EOF
                exit 1
                ;;
            *)
                echo >&2
                msg=$(printf '%s' "$TTN_RESPONSE" | json_str message)
                cat >&2 <<EOF
ERROR: TTN refused the gateway registration (HTTP $HTTP_STATUS).
  TTN says: ${msg:-(no message)}

What to do: re-run linxdot-setup. If the same error recurs, copy the
TTN message above and check the TTN forum / open an issue.
EOF
                exit 1
                ;;
        esac
    fi

    # ---- LNS API key: reuse, auto-create, or prompt for paste ----------
    if [ -n "$LNS_KEY_OVERRIDE" ]; then
        echo "Using the LNS key you pasted (skipping auto-create)." >&2
        lns_key=$LNS_KEY_OVERRIDE
    else
        body='{"name":"openlinxdot-lns","rights":["RIGHT_GATEWAY_LINK"]}'
        printf "Creating LNS key for '%s'… " "$gid" >&2
        ttn_request POST "/api/v3/gateways/${gid}/api-keys" "$body"
        case "$HTTP_STATUS" in
            200|201)
                echo "OK" >&2
                lns_key=$(printf '%s' "$TTN_RESPONSE" | json_str key)
                case "$lns_key" in
                    NNSXS.*) ;;
                    *)  echo "  Response missing 'key' — falling back to manual paste." >&2
                        ask_lns_for_known_gateway
                        lns_key=$LNS_KEY_OVERRIDE
                        ;;
                esac
                ;;
            *)
                echo "FAIL ($HTTP_STATUS)" >&2
                ask_lns_for_known_gateway
                lns_key=$LNS_KEY_OVERRIDE
                ;;
        esac
    fi

    # ---- Configure cluster on basicstation -----------------------------
    # Persist the operator's region choice as a tiny env file. The rootfs
    # docker-compose.yml interpolates ${TTS_REGION:-eu1}, so this single
    # value survives OTA without freezing a whole compose-file snapshot
    # on /data.
    echo "Configuring basicstation for cluster $TTN_CLUSTER…" >&2
    echo "TTS_REGION=$TTN_CLUSTER" > /data/basicstation/region.env

    # ---- Install LNS key + restart + verify ----------------------------
    printf '%s\n' "$lns_key" > "$TC_KEY"
    chmod 600 "$TC_KEY"
    echo "LNS key saved. Restarting basicstation…" >&2
    /etc/init.d/S80dockercompose restart >/dev/null 2>&1 || true

    # ---- Verification: device side -----------------------------------
    while :; do
        printf "Waiting for basicstation to reach TTN (up to %d s)…\n" "$MUXS_TIMEOUT" >&2
        if wait_for_muxs; then
            echo "  TLS handshake to ${TTN_CLUSTER}.cloud.thethings.network OK — basicstation Connected to MUXS." >&2
            break
        fi
        cat >&2 <<EOF

ERROR: basicstation did not reach 'Connected to MUXS' within ${MUXS_TIMEOUT}s.
The gateway IS registered on TTN and the LNS key IS installed — this is
almost always a device-side network or clock issue.

What to do:
  1. Inspect basicstation: docker logs basicstation 2>&1 | tail -30
  2. Common causes:
     - stale clock → run: /usr/sbin/clock-bootstrap
     - wrong region → edit /data/docker-compose.yml (TTS_REGION:),
       then: /etc/init.d/S80dockercompose restart
     - blocked outbound TCP/443 + 8887 to ${TTN_CLUSTER}.cloud.thethings.network
EOF
        prompt_retry || exit 1
    done

    # forget the bootstrap key — never persisted to disk
    TTN_API_KEY=

    write_state setup-complete

    cat <<EOF

================================================================
 Setup complete — your gateway is live on TTN.
================================================================

  Gateway name : $gid
  Gateway EUI  : $eui
  Cluster      : $TTN_CLUSTER
  Connection   : Connected to MUXS

Send your first uplink to confirm the LoRa side.

You're done. The wizard won't prompt again on this device. To redo
setup from scratch, remove /data/.setup-state and run linxdot-setup.

EOF
}

phase_complete() {
    cat <<EOF
Setup is complete. Current state:

EOF
    if [ -s "$TC_KEY" ]; then
        printf "  TC key      : present (%d bytes)\n" "$(wc -c < "$TC_KEY")"
    else
        printf "  TC key      : missing — re-run after \`rm %s\`\n" "$STATE_FILE"
    fi
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^basicstation$'; then
        echo "  basicstation: running"
    else
        echo "  basicstation: NOT running — try: /etc/init.d/S80dockercompose start"
    fi
    if docker logs basicstation 2>&1 | grep -q "Connected to MUXS"; then
        echo "  TTN          : connected"
    else
        echo "  TTN          : not connected — see: docker logs basicstation"
    fi
    echo
    echo "To redo setup from scratch: rm $STATE_FILE && linxdot-setup"
}

# --- main ---

print_banner
print_status

state=$(read_state)
case "$state" in
    fresh)
        phase_a
        ;;
    mac-bound)
        phase_b
        ;;
    setup-complete)
        phase_complete
        ;;
    *)
        echo "Unknown setup state: $state"
        echo "Reset with: rm $STATE_FILE && linxdot-setup"
        exit 1
        ;;
esac
