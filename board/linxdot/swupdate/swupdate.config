#
# Linxdot LD1001 SWUpdate configuration.
# Derived from Buildroot's upstream package/swupdate/swupdate.config with the
# minimal changes needed for OpenLinxdot's A/B OTA flow:
#
#   - CONFIG_BOOTLOADER_UBOOT=y + CONFIG_UBOOT_NEWAPI=y
#       (so `bootenv:` in sw-description actually writes boot_slot /
#       upgrade_available; default BOOTLOADER_NONE silently drops the section)
#   - CONFIG_SSL_IMPL_OPENSSL=y
#       (required for hash + signature verification; default IMPL_NONE makes
#       sha256 and signature checks no-ops)
#   - CONFIG_HASH_VERIFY=y
#       (enforce sha256 entries in sw-description)
#   - CONFIG_SIGNED_IMAGES=y + CONFIG_SIGALG_RAWRSA=y
#       (matches `openssl dgst -sha256 -sign` used in build.yml)
#   - Webserver disabled (we don't expose a local SWUpdate UI)
#
CONFIG_HAVE_DOT_CONFIG=y

#
# Swupdate Settings
#

#
# General Configuration
#
# CONFIG_CURL is not set
# CONFIG_CURL_SSL is not set
# CONFIG_SYSTEMD is not set
CONFIG_DEFAULT_CONFIG_FILE="/etc/swupdate.cfg"
CONFIG_SCRIPTS=y
# CONFIG_HW_COMPATIBILITY is not set
CONFIG_SW_VERSIONS_FILE="/etc/sw-versions"

#
# Socket Paths
#
CONFIG_SOCKET_CTRL_PATH="/tmp/sockinstctrl"
CONFIG_SOCKET_PROGRESS_PATH="/tmp/swupdateprog"
CONFIG_SOCKET_REMOTE_HANDLER_DIRECTORY="/tmp/"

#
# MTD support needs libmtd
#

#
# Lua support needs a Lua interpreter
#
# CONFIG_FEATURE_SYSLOG is not set

#
# Build Options
#
CONFIG_CROSS_COMPILE=""
CONFIG_SYSROOT=""
CONFIG_EXTRA_CFLAGS=""
CONFIG_EXTRA_LDFLAGS=""
CONFIG_EXTRA_LDLIBS=""

#
# Debugging Options
#
# CONFIG_DEBUG is not set
# CONFIG_WERROR is not set
# CONFIG_NOCLEANUP is not set

#
# Bootloader support
#
# CONFIG_BOOTLOADER_EBG is not set
# CONFIG_BOOTLOADER_NONE is not set
CONFIG_BOOTLOADER_UBOOT=y
CONFIG_UBOOT_NEWAPI=y
# CONFIG_BOOTLOADER_GRUB is not set

#
# SSL implementation
#
CONFIG_SSL_IMPL_OPENSSL=y
# CONFIG_SSL_IMPL_WOLFSSL is not set
# CONFIG_SSL_IMPL_MBEDTLS is not set
# CONFIG_SSL_IMPL_NONE is not set

#
# Hash checking
#
CONFIG_HASH_VERIFY=y

#
# Image signature verification
#
# CONFIG_SIGNED_IMAGES is deliberately NOT enabled for now. With SIGNED_IMAGES
# set, swupdate rejects any bundle without a matching sw-description.sig — but
# CI only produces signed bundles if the OTA_SIGNING_KEY GitHub secret is set.
# Until a signing keypair is generated and deployed (scripts/gen-signing-key.sh
# → public.pem committed to overlay + private half in OTA_SIGNING_KEY secret),
# we want swupdate to accept the unsigned happy-path bundle.
#
# Flipping this to =y is TC-4.3 — must be coordinated with the overlay
# public.pem drop + CI signing.
# CONFIG_SIGNED_IMAGES is not set

#
# Image encryption
#
# CONFIG_ENCRYPTED_IMAGES is not set

# CONFIG_SURICATTA is not set
# CONFIG_WEBSERVER is not set

#
# Parser Features
#
CONFIG_LIBCONFIG=y
CONFIG_PARSERROOT=""

#
# JSON config parser support needs json-c
#
# CONFIG_SETSWDESCRIPTION is not set

#
# Image Handlers
#

#
# ubivol support needs libubi
#
# CONFIG_DISKPART is not set
CONFIG_RAW=y
# CONFIG_RDIFFHANDLER is not set
# CONFIG_SHELLSCRIPTHANDLER is not set

#
# archive support needs libarchive
#

#
# remote handler needs zeromq
#

#
# swuforward handler needs json-c and curl
#

#
# SWU forwarder requires libcurl
#

#
# swuforward handler needs json-c and curl
#
# CONFIG_BOOTLOADERHANDLER is not set

#
# Microcontroller handler depends on libgpiod
#
