software =
{
    version = "@VERSION@";
    description = "OpenLinxdot firmware update";
    hardware-compatibility: [ "linxdot-ld1001" ];

    /*
     * SWUpdate's selector splits only at the first comma:
     *   -e stable,target-B  ->  software_set="stable", running_mode="target-B"
     * The parser then looks up software.<set>.<mode>, joining with dots.
     * A nested "linxdot-ld1001 { target-B { ... } }" would require a key
     * literally named "linxdot-ld1001,target-B" — libconfig path lookup
     * can't reach it. Hardware identity is enforced via hardware-compatibility
     * (above) and /etc/hwrevision; no need for an extra nesting level.
     */
    stable:
    {
        /* Invoke with -e stable,target-B when current slot is A. */
        target-B:
        {
            images: (
                {
                    filename = "rootfs.ext4";
                    device = "/dev/mmcblk1p4";
                    type = "raw";
                    installed-directly = true;
                    sha256 = "@SHA_ROOTFS@";
                },
                {
                    filename = "boot.vfat";
                    device = "/dev/mmcblk1p3";
                    type = "raw";
                    installed-directly = true;
                    sha256 = "@SHA_BOOT@";
                }
            );
            bootenv: (
                { name = "boot_slot";         value = "B"; },
                { name = "upgrade_available"; value = "1"; },
                { name = "bootcount";         value = "0"; }
            );
        };

        /* Invoke with -e stable,target-A when current slot is B. */
        target-A:
        {
            images: (
                {
                    filename = "rootfs.ext4";
                    device = "/dev/mmcblk1p2";
                    type = "raw";
                    installed-directly = true;
                    sha256 = "@SHA_ROOTFS@";
                },
                {
                    filename = "boot.vfat";
                    device = "/dev/mmcblk1p1";
                    type = "raw";
                    installed-directly = true;
                    sha256 = "@SHA_BOOT@";
                }
            );
            bootenv: (
                { name = "boot_slot";         value = "A"; },
                { name = "upgrade_available"; value = "1"; },
                { name = "bootcount";         value = "0"; }
            );
        };
    };
};
